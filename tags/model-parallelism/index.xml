    <item>
      <title>Distributed Training: Model Parallelism (TP, PP, SP, EP, 3D)</title>
      <link>https://liuyiyueyue.github.io/llm/distributed_training_4_model_parallelism/</link>
      <pubDate>Wed, 17 Dec 2025 00:00:00 +0000</pubDate>
